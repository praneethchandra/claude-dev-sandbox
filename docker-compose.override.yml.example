# docker-compose.override.yml.example
# cp docker-compose.override.yml.example docker-compose.override.yml
# Edit, then: make restart

services:
  claude-dev:
    volumes:
      # Mount your Mac projects folder so files are visible in both places:
      # ~/projects/my-app on Mac = /workspace/my-app in container
      - ~/projects:/workspace

      # Git identity inside container
      - ~/.gitconfig:/root/.gitconfig:ro

      # SSH keys for git push to GitHub
      # - ~/.ssh:/root/.ssh:ro

      # AWS credentials for Bedrock auth
      # - ~/.aws:/root/.aws:ro

      # GCP credentials for Vertex AI auth
      # - ~/.config/gcloud:/root/.config/gcloud:ro
