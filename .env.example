# ─────────────────────────────────────────────────────────────────
# .env.example  —  Claude Code Dev Sandbox
#
# 1. cp .env.example .env
# 2. Fill in ANTHROPIC_API_KEY
# 3. Never commit .env  (it's in .gitignore)
#
# Get your key: https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────────

# Required
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional — model used by Claude Code sessions
# Options: claude-opus-4-8 | claude-opus-4-7 | claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — shown in shell prompt
WORKSPACE_NAME=workspace

# Optional — set to 1 to opt out of telemetry
CLAUDE_CODE_DISABLE_TELEMETRY=0
