{
  "name": "Claude Code Dev Sandbox",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "args": { "CLAUDE_CODE_VERSION": "latest" }
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "ANTHROPIC_MODEL":   "${localEnv:ANTHROPIC_MODEL}",
    "TERM": "xterm-256color"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/claude-dev-sandbox,type=bind,consistency=cached",
  "workspaceFolder": "/workspace/claude-dev-sandbox",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly",
    "source=claude-config,target=/root/.claude,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "eamodio.gitlens",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "usernamehw.errorlens",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.rulers": [100],
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh" }
        }
      }
    }
  },
  "forwardPorts": [3000, 3001, 5173, 8000, 8080],
  "portsAttributes": {
    "3000": { "label": "Dev server", "onAutoForward": "notify" },
    "5173": { "label": "Vite",       "onAutoForward": "notify" },
    "8000": { "label": "API",        "onAutoForward": "notify" }
  },
  "postCreateCommand": "install-plugins minimal && help-claude",
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
