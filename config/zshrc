# ─────────────────────────────────────────────────────────────────
# ~/.zshrc — Claude Code Dev Sandbox shell config
# ─────────────────────────────────────────────────────────────────

# ── Oh My Zsh ────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git node npm python colored-man-pages)
source $ZSH/oh-my-zsh.sh

# ── Environment ──────────────────────────────────────────────────
export PATH="$PATH:/usr/local/claude-scripts"
export EDITOR="nano"
export TERM="xterm-256color"

# ── Claude Code: Mode aliases ────────────────────────────────────
alias cc-minimal='switch-mode minimal'
alias cc-balanced='switch-mode balanced'
alias cc-full='switch-mode full'
alias cc-tdd='switch-mode tdd'
alias cc-mode='switch-mode show'
alias ccm='switch-mode minimal'
alias ccb='switch-mode balanced'
alias ccf='switch-mode full'
alias cct='switch-mode tdd'

# ── Claude Code: Shortcut launchers ─────────────────────────────
# Start with a specific mode in one command
alias claude-min='ccm && claude'
alias claude-bal='ccb && claude'
alias claude-ful='ccf && claude'
alias claude-tdd='cct && claude'

# Headless / scripted mode
alias claude-auto='claude --enable-auto-mode'
alias claude-run='claude -p'        # claude-run "fix the type errors"

# ── Claude Code: Dynamic Workflows (May 2026) ────────────────────
alias claude-flow='claude --enable-auto-mode'   # workflows need auto mode

# ── Project shortcuts ─────────────────────────────────────────────
alias ncp='new-project'
alias cdw='cd /workspace'           # jump to workspace root
alias ls-projects='ls -la /workspace'

# ── Git shortcuts ─────────────────────────────────────────────────
alias gs='git status'
alias ga='git add -p'
alias gc='git commit -m'
alias gd='git diff'
alias gl='git log --oneline -10'

# ── Worktree helpers (for multi-agent) ────────────────────────────
# Usage: wt-add feature/my-branch /workspace/my-project-agent1
wt-add() {
    if [ $# -lt 2 ]; then
        echo "Usage: wt-add <branch> <path>"
        return 1
    fi
    git worktree add "$2" "$1" && echo "✓ Worktree ready: $2"
}

wt-rm() {
    if [ $# -lt 1 ]; then
        echo "Usage: wt-rm <path>"
        return 1
    fi
    git worktree remove "$1" && echo "✓ Worktree removed: $1"
}

wt-list() {
    git worktree list
}

# ── Help function ─────────────────────────────────────────────────
help-claude() {
    echo ""
    echo "  Claude Code Dev Sandbox — Quick Reference"
    echo "  ─────────────────────────────────────────────────────"
    echo ""
    echo "  Mode switching:"
    echo "    ccm / cc-minimal     Minimal mode (small fixes)"
    echo "    ccb / cc-balanced    Balanced mode (features) ← default"
    echo "    ccf / cc-full        Full mode (reviews, architecture)"
    echo "    cct / cc-tdd         TDD mode (new modules)"
    echo "    cc-mode              Show current mode"
    echo ""
    echo "  Project management:"
    echo "    new-project <name> [typescript|python|fullstack|generic]"
    echo "    cdw                  cd to /workspace"
    echo "    ls-projects          list all projects"
    echo ""
    echo "  Starting Claude Code:"
    echo "    claude               Interactive session (current mode)"
    echo "    claude-auto          With auto mode (approve routine actions)"
    echo "    claude-run 'prompt'  Headless one-shot"
    echo ""
    echo "  Inside Claude Code (slash commands):"
    echo "    /stage               Current lifecycle stage + next actions"
    echo "    /plan                Step-by-step plan before acting"
    echo "    /next                Advance to next lifecycle stage"
    echo "    /review              Full code audit"
    echo "    /test                Generate tests for current file"
    echo "    /security            Security vulnerability checklist"
    echo "    /effort [level]      Set reasoning depth (low→max)"
    echo "    /ultrareview [PR#]   Cloud parallel code review"
    echo "    /workflows           View dynamic workflow runs"
    echo "    /voice               Enable push-to-talk"
    echo "    /plugin              Manage MCP plugins"
    echo ""
    echo "  Multi-agent (git worktrees):"
    echo "    wt-add <branch> <path>   Create agent workspace"
    echo "    wt-rm <path>             Remove after done"
    echo "    wt-list                  Show all worktrees"
    echo ""
    echo "  Plugins:"
    echo "    install-plugins [minimal|frontend|all]"
    echo ""
}

# ── Welcome shortcut ──────────────────────────────────────────────
alias welcome='cat /etc/claude-welcome 2>/dev/null || help-claude'
