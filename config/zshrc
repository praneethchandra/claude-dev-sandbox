export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git node npm python colored-man-pages)
source $ZSH/oh-my-zsh.sh

export PATH="$PATH:/usr/local/claude-scripts"
export EDITOR="nano"
export TERM="xterm-256color"

alias cc-minimal='switch-mode minimal'
alias cc-balanced='switch-mode balanced'
alias cc-full='switch-mode full'
alias cc-tdd='switch-mode tdd'
alias cc-mode='switch-mode show'
alias ccm='switch-mode minimal'
alias ccb='switch-mode balanced'
alias ccf='switch-mode full'
alias cct='switch-mode tdd'
alias claude-auto='claude --enable-auto-mode'
alias claude-run='claude -p'
alias ncp='new-project'
alias cdw='cd /workspace'
alias ls-projects='ls -la /workspace'
alias ccmetrics='python3 /usr/local/claude-scripts/metrics.py'
alias ccmetrics-detail='python3 /usr/local/claude-scripts/metrics.py --detail'
alias ccmetrics-today='python3 /usr/local/claude-scripts/metrics.py --today'
alias gs='git status'
alias ga='git add -p'
alias gc='git commit -m'
alias gd='git diff'
alias gl='git log --oneline -10'

wt-add()  { git worktree add "$2" "$1" && echo "Worktree ready: $2"; }
wt-rm()   { git worktree remove "$1" && echo "Removed: $1"; }
wt-list() { git worktree list; }

help-claude() {
  echo ""
  echo "  Claude Code Dev Sandbox"
  echo "  ─────────────────────────────────────────────────"
  echo "  Modes:    ccm minimal  ccb balanced  ccf full  cct tdd"
  echo "  Projects: new-project <name> [typescript|python|fullstack]"
  echo "  Metrics:  ccmetrics | ccmetrics-detail | ccmetrics-today"
  echo "  Session:  /cost  /plan  /review  /test  /stage  /next"
  echo "  Agents:   wt-add <branch> <path>  wt-rm <path>  wt-list"
  echo ""
}
